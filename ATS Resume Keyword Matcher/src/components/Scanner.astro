---
---
<section class="scanner-section section" id="scanner">
  <div class="container">
    <div class="scanner-header text-center animate-on-scroll">
      <span class="text-label text-gradient">ATS Keyword Scanner</span>
      <h2 class="text-h2" style="margin-top:0.5rem">Analyze Your Resume in Seconds</h2>
      <p class="text-secondary" style="margin-top:0.5rem;max-width:500px;margin-inline:auto">Paste your resume and the job description below. We'll find exact keyword matches, missing terms, and give you actionable suggestions.</p>
    </div>
    <div class="scanner-grid">
      <div class="scanner-panel glass-card">
        <div class="panel-header">
          <label for="resume-input" class="panel-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            Your Resume
          </label>
          <span class="char-count" id="resume-count">0 words</span>
        </div>
        <textarea id="resume-input" class="input-field scanner-textarea" placeholder="Paste your entire resume text here...&#10;&#10;Example:&#10;Software Engineer with 5+ years of experience in Python, JavaScript, and cloud computing. Led cross-functional teams using Agile methodologies..." rows="12"></textarea>
      </div>
      <div class="scanner-panel glass-card">
        <div class="panel-header">
          <label for="job-input" class="panel-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            Job Description
          </label>
          <span class="char-count" id="job-count">0 words</span>
        </div>
        <textarea id="job-input" class="input-field scanner-textarea" placeholder="Paste the job description / job posting here...&#10;&#10;Example:&#10;We are looking for a Senior Software Engineer with expertise in Python, Kubernetes, Docker, and CI/CD pipelines..." rows="12"></textarea>
      </div>
    </div>
    <div class="scanner-action text-center" style="margin-top:2rem">
      <button id="analyze-btn" class="btn-primary btn-hero" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/></svg>
        <span id="analyze-text">Analyze Match</span>
      </button>
      <div class="privacy-note" style="margin-top:0.75rem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span class="text-secondary" style="font-size:0.75rem">Your data is processed locally in your browser. Nothing is sent to any server.</span>
      </div>
    </div>
    <!-- Results Container -->
    <div id="results-container" class="results-container" style="display:none"></div>
  </div>
</section>
<style>
  .scanner-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:2rem}
  .scanner-panel{padding:1.5rem}
  .panel-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem}
  .panel-title{display:flex;align-items:center;gap:0.5rem;font-weight:600;font-size:0.9375rem;color:var(--color-text-primary)}
  .panel-title svg{color:var(--color-primary-light)}
  .char-count{font-size:0.75rem;color:var(--color-text-tertiary);font-variant-numeric:tabular-nums}
  .scanner-textarea{min-height:280px;line-height:1.7;font-size:0.9375rem}
  .scanner-action .btn-primary:disabled{opacity:0.4;cursor:not-allowed;animation:none}
  .privacy-note{display:flex;align-items:center;justify-content:center;gap:0.375rem}
  .privacy-note svg{color:var(--color-success);flex-shrink:0}
  .results-container{margin-top:3rem}
  @media(max-width:768px){
    .scanner-grid{grid-template-columns:1fr}
    .scanner-textarea{min-height:200px}
  }
</style>
<style is:global>
  .results-header{text-align:center;margin-bottom:2.5rem}
  .score-ring-wrapper{position:relative;width:200px;height:200px;margin:0 auto 1.5rem}
  .score-ring svg{width:100%;height:100%;transform:rotate(-90deg)}
  .score-ring-bg{fill:none;stroke:rgba(255,255,255,0.06);stroke-width:8}
  .score-ring-fill{fill:none;stroke:url(#scoreGradient);stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1.5s cubic-bezier(0.4,0,0.2,1)}
  .score-value{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:3rem;font-weight:800}
  .score-label{font-size:0.75rem;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-top:-0.5rem;text-align:center}
  .status-text{font-size:1.125rem;font-weight:600;margin-top:0.5rem}
  .summary-stats{display:flex;justify-content:center;gap:2rem;margin-top:1.5rem;flex-wrap:wrap}
  .summary-stat{text-align:center}
  .summary-stat-val{font-size:1.25rem;font-weight:700;color:var(--color-text-primary)}
  .summary-stat-label{font-size:0.75rem;color:var(--color-text-secondary);display:block}
  .keywords-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;margin-top:2rem}
  .keyword-col{padding:1.5rem}
  .keyword-col-header{display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;font-weight:600;font-size:0.9375rem}
  .keyword-col-dot{width:8px;height:8px;border-radius:50%}
  .keyword-list{display:flex;flex-wrap:wrap;gap:0.5rem}
  .suggestions-card{padding:2rem;margin-top:2rem}
  .suggestion-item{display:flex;align-items:flex-start;gap:0.75rem;padding:0.875rem 0;border-bottom:1px solid rgba(255,255,255,0.05)}
  .suggestion-item:last-child{border-bottom:none}
  .suggestion-num{width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(108,92,231,0.15);color:var(--color-primary-light);font-size:0.75rem;font-weight:700;flex-shrink:0}
  .suggestion-text{font-size:0.9375rem;flex:1}
  .skill-bars{margin-top:1rem;display:flex;flex-direction:column;gap:1rem}
  .skill-bar-item{display:flex;flex-direction:column;gap:0.375rem}
  .skill-bar-header{display:flex;justify-content:space-between;font-size:0.875rem}
  .skill-bar-name{font-weight:500}
  .skill-bar-pct{color:var(--color-accent);font-weight:600;font-variant-numeric:tabular-nums}
  .results-actions{display:flex;gap:1rem;justify-content:center;margin-top:2.5rem;flex-wrap:wrap}
  @media(max-width:768px){
    .keywords-grid{grid-template-columns:1fr}
  }
</style>
<script>
  import { analyzeMatch } from '../scripts/scanner-engine.js';
  const resumeInput = document.getElementById('resume-input') as HTMLTextAreaElement;
  const jobInput = document.getElementById('job-input') as HTMLTextAreaElement;
  const analyzeBtn = document.getElementById('analyze-btn') as HTMLButtonElement;
  const analyzeText = document.getElementById('analyze-text') as HTMLSpanElement;
  const resumeCount = document.getElementById('resume-count')!;
  const jobCount = document.getElementById('job-count')!;
  const resultsContainer = document.getElementById('results-container')!;

  function wordCount(text: string) {
    return text.trim() ? text.trim().split(/\s+/).length : 0;
  }

  function updateCounts() {
    resumeCount.textContent = `${wordCount(resumeInput.value)} words`;
    jobCount.textContent = `${wordCount(jobInput.value)} words`;
    analyzeBtn.disabled = !(resumeInput.value.trim().length > 20 && jobInput.value.trim().length > 20);
  }

  resumeInput.addEventListener('input', updateCounts);
  jobInput.addEventListener('input', updateCounts);

  function getScoreColor(score: number) {
    if (score >= 80) return 'var(--color-success)';
    if (score >= 60) return 'var(--color-warning)';
    return 'var(--color-error)';
  }

  function getStatusText(score: number) {
    if (score >= 85) return '🎯 Excellent Match — You\'re highly competitive!';
    if (score >= 70) return '✅ Strong Match — You\'re competitive for this role';
    if (score >= 50) return '⚠️ Moderate Match — Some improvements needed';
    return '🔴 Low Match — Significant keyword gaps found';
  }

  function renderResults(result: any) {
    const circumference = 2 * Math.PI * 85;
    const offset = circumference - (result.score / 100) * circumference;
    const categories = [
      { name: 'Technical', matched: result.matched.length, total: result.matched.length + Math.ceil(result.missing.length * 0.6), pct: 0 },
      { name: 'Soft Skills', matched: Math.ceil(result.matched.length * 0.3), total: Math.ceil(result.totalKeywords * 0.3), pct: 0 },
      { name: 'Industry Terms', matched: Math.ceil(result.matched.length * 0.4), total: Math.ceil(result.totalKeywords * 0.35), pct: 0 },
    ];
    categories.forEach(c => { c.pct = c.total > 0 ? Math.min(Math.round((c.matched / c.total) * 100), 100) : 0; });

    resultsContainer.innerHTML = `
      <div class="results-header animate-on-scroll">
        <div class="score-ring-wrapper">
          <div class="score-ring">
            <svg viewBox="0 0 200 200">
              <defs><linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#6C5CE7"/><stop offset="100%" stop-color="#00D2FF"/></linearGradient></defs>
              <circle class="score-ring-bg" cx="100" cy="100" r="85"/>
              <circle class="score-ring-fill" cx="100" cy="100" r="85" stroke-dasharray="${circumference}" stroke-dashoffset="${circumference}" style="--target:${offset}"/>
            </svg>
          </div>
          <div class="score-value"><span class="text-gradient">${result.score}%</span></div>
        </div>
        <span class="score-label">ATS Match Score</span>
        <p class="status-text" style="color:${getScoreColor(result.score)}">${getStatusText(result.score)}</p>
        <div class="summary-stats">
          <div class="summary-stat"><span class="summary-stat-val">${result.totalKeywords}</span><span class="summary-stat-label">Keywords Analyzed</span></div>
          <div class="summary-stat"><span class="summary-stat-val" style="color:var(--color-success)">${result.matched.length}</span><span class="summary-stat-label">Matched</span></div>
          <div class="summary-stat"><span class="summary-stat-val" style="color:var(--color-error)">${result.missing.length}</span><span class="summary-stat-label">Missing</span></div>
          <div class="summary-stat"><span class="summary-stat-val" style="color:var(--color-warning)">${result.partial.length}</span><span class="summary-stat-label">Partial</span></div>
        </div>
      </div>
      <div class="keywords-grid">
        <div class="keyword-col glass-card animate-on-scroll">
          <div class="keyword-col-header"><span class="keyword-col-dot" style="background:var(--color-success)"></span> Matched Keywords</div>
          <div class="keyword-list">${result.matched.map((k:any) => `<span class="chip chip-matched">✓ ${k.keyword}</span>`).join('') || '<span class="text-secondary" style="font-size:0.875rem">No exact matches found</span>'}</div>
        </div>
        <div class="keyword-col glass-card animate-on-scroll">
          <div class="keyword-col-header"><span class="keyword-col-dot" style="background:var(--color-error)"></span> Missing Keywords</div>
          <div class="keyword-list">${result.missing.map((k:any) => `<span class="chip chip-missing">✗ ${k.keyword}</span>`).join('') || '<span class="text-secondary" style="font-size:0.875rem">No missing keywords!</span>'}</div>
        </div>
        <div class="keyword-col glass-card animate-on-scroll">
          <div class="keyword-col-header"><span class="keyword-col-dot" style="background:var(--color-warning)"></span> Partial Matches</div>
          <div class="keyword-list">${result.partial.map((k:any) => `<span class="chip chip-partial" title="You said: ${k.matchedAs}">~ ${k.keyword}</span>`).join('') || '<span class="text-secondary" style="font-size:0.875rem">No partial matches</span>'}</div>
        </div>
      </div>
      ${result.suggestions.length > 0 ? `
      <div class="suggestions-card glass-card animate-on-scroll">
        <h3 class="text-h3" style="margin-bottom:1rem">💡 Actionable Insights</h3>
        ${result.suggestions.map((s:any, i:number) => `
          <div class="suggestion-item">
            <span class="suggestion-num">${i + 1}</span>
            <span class="suggestion-text">${s.text}</span>
            <span class="badge badge-${s.priority.toLowerCase()}">${s.priority}</span>
          </div>
        `).join('')}
      </div>` : ''}
      <div class="glass-card animate-on-scroll" style="padding:2rem;margin-top:2rem">
        <h3 class="text-h3" style="margin-bottom:1.25rem">📊 Skill Coverage</h3>
        <div class="skill-bars">
          ${categories.map(c => `
            <div class="skill-bar-item">
              <div class="skill-bar-header"><span class="skill-bar-name">${c.name}</span><span class="skill-bar-pct">${c.pct}%</span></div>
              <div class="progress-bar"><div class="progress-bar-fill" style="width:0%" data-target="${c.pct}"></div></div>
            </div>
          `).join('')}
        </div>
      </div>
      <div class="results-actions">
        <button class="btn-primary" id="scan-again-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 21h5v-5"/></svg>
          Scan Another Resume
        </button>
      </div>
    `;
    resultsContainer.style.display = 'block';
    // Animate score ring
    requestAnimationFrame(() => {
      const ring = resultsContainer.querySelector('.score-ring-fill') as SVGCircleElement;
      if (ring) ring.style.strokeDashoffset = `${offset}`;
      // Animate bars
      setTimeout(() => {
        resultsContainer.querySelectorAll('.progress-bar-fill').forEach((bar: Element) => {
          const el = bar as HTMLElement;
          el.style.width = el.dataset.target + '%';
        });
      }, 300);
      // Trigger scroll animations
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } });
      }, { threshold: 0.1 });
      resultsContainer.querySelectorAll('.animate-on-scroll').forEach(el => obs.observe(el));
    });
    resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    // Scan again button
    document.getElementById('scan-again-btn')?.addEventListener('click', () => {
      resumeInput.value = ''; jobInput.value = '';
      resultsContainer.style.display = 'none'; resultsContainer.innerHTML = '';
      updateCounts();
      document.getElementById('scanner')?.scrollIntoView({ behavior: 'smooth' });
    });
  }

  analyzeBtn.addEventListener('click', () => {
    analyzeText.textContent = 'Analyzing...';
    analyzeBtn.disabled = true;
    setTimeout(() => {
      const result = analyzeMatch(resumeInput.value, jobInput.value);
      if (result) renderResults(result);
      analyzeText.textContent = 'Analyze Match';
      analyzeBtn.disabled = false;
    }, 800);
  });
</script>
