---
---
<section class="features section" id="how-it-works">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <span class="text-label text-gradient">How It Works</span>
      <h2 class="text-h2" style="margin-top:0.5rem">Three Steps to Beat the ATS</h2>
      <p class="text-secondary" style="margin-top:0.5rem;max-width:500px;margin-inline:auto">No sign-ups, no uploads, no waiting. Just paste and scan.</p>
    </div>
    <div class="steps-grid">
      <div class="step-card glass-card animate-on-scroll">
        <div class="step-number text-gradient">01</div>
        <div class="step-icon">📄</div>
        <h3 class="text-h3">Paste Your Resume</h3>
        <p class="text-secondary">Copy your entire resume text and paste it into the left panel. No file uploads needed — your data stays on your device.</p>
      </div>
      <div class="step-card glass-card animate-on-scroll">
        <div class="step-number text-gradient">02</div>
        <div class="step-icon">💼</div>
        <h3 class="text-h3">Add Job Description</h3>
        <p class="text-secondary">Paste the job posting you're targeting. Our engine extracts the most important keywords and requirements automatically.</p>
      </div>
      <div class="step-card glass-card animate-on-scroll">
        <div class="step-number text-gradient">03</div>
        <div class="step-icon">🎯</div>
        <h3 class="text-h3">Get Your Score</h3>
        <p class="text-secondary">Instantly see your ATS match score, matched & missing keywords, and prioritized suggestions to improve your resume.</p>
      </div>
    </div>
  </div>
</section>
<section class="features-detail section" id="features">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <span class="text-label text-gradient">Why ResumeRadar</span>
      <h2 class="text-h2" style="margin-top:0.5rem">Built Different</h2>
    </div>
    <div class="features-grid">
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">🔒</div>
        <h3>100% Private</h3>
        <p class="text-secondary">Your resume is processed entirely in your browser. No data is ever sent to any server. Period.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">⚡</div>
        <h3>Instant Results</h3>
        <p class="text-secondary">No loading screens, no queues. Get your ATS match score and keyword analysis in under 2 seconds.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">💯</div>
        <h3>Free Forever</h3>
        <p class="text-secondary">No paywalls, no "premium" tiers, no account required. Scan unlimited resumes, always.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">🧠</div>
        <h3>Smart Matching</h3>
        <p class="text-secondary">Recognizes synonyms, abbreviations, and related terms. "AWS" matches "Amazon Web Services" automatically.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">📊</div>
        <h3>Actionable Insights</h3>
        <p class="text-secondary">Don't just see a score — get prioritized suggestions on exactly which keywords to add and where.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">📱</div>
        <h3>Works Everywhere</h3>
        <p class="text-secondary">Fully responsive. Use it on your phone, tablet, or desktop — no app download required.</p>
      </div>
    </div>
  </div>
</section>
<style>
  .steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
  .step-card{padding:2rem;text-align:center;position:relative;overflow:hidden}
  .step-number{font-size:3rem;font-weight:900;opacity:0.15;position:absolute;top:1rem;right:1.5rem}
  .step-icon{font-size:2.5rem;margin-bottom:1rem}
  .step-card h3{margin-bottom:0.75rem}
  .step-card p{font-size:0.9375rem;line-height:1.7}
  .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
  .feature-item{padding:1.75rem;transition:transform 0.3s,border-color 0.3s}
  .feature-item:hover{transform:translateY(-4px)}
  .feature-icon{font-size:2rem;margin-bottom:0.75rem}
  .feature-item h3{font-size:1.0625rem;font-weight:700;margin-bottom:0.5rem}
  .feature-item p{font-size:0.875rem;line-height:1.7}
  @media(max-width:768px){.steps-grid,.features-grid{grid-template-columns:1fr}}
</style>
