---
---
<section class="features section" id="how-it-works">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <span class="text-label text-gradient">How It Works</span>
      <h2 class="text-h2" style="margin-top:0.5rem">Three Steps to Clean Data</h2>
      <p class="text-secondary" style="margin-top:0.5rem;max-width:500px;margin-inline:auto">No sign-ups, no server uploads, no waiting. Just drop and clean.</p>
    </div>
    <div class="steps-grid">
      <div class="step-card glass-card animate-on-scroll">
        <div class="step-number text-gradient">01</div>
        <div class="step-icon">📁</div>
        <h3 class="text-h3">Drop Your CSV</h3>
        <p class="text-secondary">Drag and drop your messy CRM export or B2B leads list. No file size limits — everything happens on your machine.</p>
      </div>
      <div class="step-card glass-card animate-on-scroll">
        <div class="step-number text-gradient">02</div>
        <div class="step-icon">⚙️</div>
        <h3 class="text-h3">Select Rules</h3>
        <p class="text-secondary">Choose how to sanitize your data: trim whitespace, fix name capitalization, deduplicate, or drop empty rows.</p>
      </div>
      <div class="step-card glass-card animate-on-scroll">
        <div class="step-number text-gradient">03</div>
        <div class="step-icon">⬇️</div>
        <h3 class="text-h3">Download Cleaned</h3>
        <p class="text-secondary">Instantly export the formatted, deduplicated CSV file ready to be uploaded to Salesforce, HubSpot, or your dialer.</p>
      </div>
    </div>
  </div>
</section>
<section class="features-detail section" id="features">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <span class="text-label text-gradient">Why DataSanitize</span>
      <h2 class="text-h2" style="margin-top:0.5rem">Built for B2B Ops</h2>
    </div>
    <div class="features-grid">
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">🔒</div>
        <h3>100% Private</h3>
        <p class="text-secondary">Your leads and customer data are processed entirely in your browser. No data is ever sent to our servers. Full compliance.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">⚡</div>
        <h3>Lightning Fast</h3>
        <p class="text-secondary">Powered by PapaParse. Clean hundreds of thousands of rows instantly without waiting for a server to respond.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">💯</div>
        <h3>Free Forever</h3>
        <p class="text-secondary">No paywalls, no "premium" tiers, no account required. Clean unlimited lists, always.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">✨</div>
        <h3>Auto-Formatting</h3>
        <p class="text-secondary">Standardizes messy name fields (e.g., "jOhN DoE" to "John Doe") and emails automatically.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">🛡️</div>
        <h3>Smart Dedupe</h3>
        <p class="text-secondary">Find and remove duplicate records based on any column (like Email or Domain) to save CRM costs.</p>
      </div>
      <div class="feature-item glass-card animate-on-scroll">
        <div class="feature-icon">🧹</div>
        <h3>Whitespace Removal</h3>
        <p class="text-secondary">Automatically strips hidden spaces and tabs that break CRM imports and email campaigns.</p>
      </div>
    </div>
  </div>
</section>
<style>
  .steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
  .step-card{padding:2rem;text-align:center;position:relative;overflow:hidden}
  .step-number{font-size:3rem;font-weight:900;opacity:0.15;position:absolute;top:1rem;right:1.5rem}
  .step-icon{font-size:2.5rem;margin-bottom:1rem}
  .step-card h3{margin-bottom:0.75rem}
  .step-card p{font-size:0.9375rem;line-height:1.7}
  .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
  .feature-item{padding:1.75rem;transition:transform 0.3s,border-color 0.3s}
  .feature-item:hover{transform:translateY(-4px)}
  .feature-icon{font-size:2rem;margin-bottom:0.75rem}
  .feature-item h3{font-size:1.0625rem;font-weight:700;margin-bottom:0.5rem}
  .feature-item p{font-size:0.875rem;line-height:1.7}
  @media(max-width:768px){.steps-grid,.features-grid{grid-template-columns:1fr}}
</style>
