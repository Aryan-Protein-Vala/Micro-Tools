---
<section class="relative pt-24 pb-16 px-6 overflow-hidden flex flex-col items-center text-center">
  <!-- Mesh Gradient Background -->
  <div class="absolute inset-0 bg-mesh-gradient opacity-60 pointer-events-none -z-10"></div>
  
  <div class="max-w-3xl w-full z-10 flex flex-col items-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-canvas-soft border border-hairline mb-8 shadow-sm">
      <span class="flex h-2 w-2 rounded-full bg-link"></span>
      <span class="text-xs font-medium text-body">v1.0 Live</span>
    </div>

    <h1 class="text-[48px] leading-[48px] tracking-[-2.4px] font-semibold text-ink mb-6">
      Visualize raw JSON arrays instantly.
    </h1>
    
    <p class="text-[18px] leading-[28px] text-body max-w-xl mb-10">
      Paste messy, deeply nested JSON arrays and automatically flatten them into a clean, sortable data table. Export to CSV in one click. 100% client-side.
    </p>

    <div class="flex items-center gap-4">
      <a href="#visualizer" class="bg-primary text-on-primary text-[16px] font-medium px-6 py-3 rounded-full hover:bg-ink/90 transition-transform hover:scale-[1.02] shadow-level-2">
        Start Visualizing
      </a>
      <a href="https://github.com/Aryan-Protein-Vala/Micro-Tools" target="_blank" class="bg-canvas text-ink border border-hairline text-[16px] font-medium px-6 py-3 rounded-full hover:bg-canvas-soft transition-transform hover:scale-[1.02] shadow-sm">
        View on GitHub
      </a>
    </div>
  </div>
</section>
