---
---
<section id="restorer" class="max-w-[1152px] mx-auto px-6 py-16 w-full flex flex-col gap-8">
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Input Column -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-ink">Broken PDF Text</h3>
      </div>
      <div class="bg-primary rounded-lg p-6 shadow-level-4 flex-1 flex flex-col relative h-[500px]">
        <textarea 
          id="raw-input" 
          class="w-full h-full bg-transparent text-on-primary font-mono text-[13px] resize-none outline-none border-none placeholder-mute leading-5"
          placeholder="Paste your broken text here...&#10;&#10;E.g.,&#10;This is a sen-&#10;tence that was broken across multiple&#10;lines in a PDF."
        ></textarea>
      </div>
      
      <!-- Formatting Options -->
      <div class="bg-canvas-soft border border-hairline p-4 rounded-md flex flex-wrap gap-4 items-center mt-2 shadow-sm">
        <span class="text-sm font-medium text-ink mr-2">Options:</span>
        <label class="flex items-center gap-2 text-sm text-body cursor-pointer">
          <input type="checkbox" id="opt-hyphen" checked class="accent-link">
          Fix Hyphens (busi- ness)
        </label>
        <label class="flex items-center gap-2 text-sm text-body cursor-pointer">
          <input type="checkbox" id="opt-lines" checked class="accent-link">
          Remove Single Line Breaks
        </label>
        <label class="flex items-center gap-2 text-sm text-body cursor-pointer">
          <input type="checkbox" id="opt-spaces" checked class="accent-link">
          Fix Double Spaces
        </label>
      </div>
    </div>

    <!-- Output Column -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-ink">Restored Text</h3>
        <button id="btn-copy" class="h-8 px-4 bg-ink text-canvas text-sm font-medium rounded-minimal hover:bg-primary transition-colors flex items-center shadow-sm gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          Copy Text
        </button>
      </div>
      <div class="bg-canvas-soft border border-hairline rounded-lg p-6 shadow-sm flex-1 flex flex-col relative h-[500px]">
        <textarea 
          id="clean-output" 
          class="w-full h-full bg-transparent text-ink font-sans text-[15px] resize-none outline-none border-none placeholder-mute leading-relaxed"
          placeholder="Clean, formatted text will appear here instantly..."
          readonly
        ></textarea>
      </div>
    </div>
  </div>

</section>

<script>
  import { initRestorer } from '../scripts/pdf-engine.js';
  document.addEventListener('DOMContentLoaded', () => {
    initRestorer();
  });
</script>
