---
import Layout from '../layouts/Layout.astro';
---

<Layout title="License | ToolGrid" description="Software licensing information for ToolGrid.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl py-20">
    <div class="prose prose-invert prose-lg max-w-none">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">License</h1>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">Tool Usage License</h2>
      <p class="text-muted-foreground mb-4">All tools hosted on ToolGrid are free to use for both personal and commercial purposes. You do not need to provide attribution to use the output generated by these tools in your own projects.</p>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">Open Source Acknowledgements</h2>
      <p class="text-muted-foreground">ToolGrid leverages several incredible open-source WebAssembly libraries and JavaScript frameworks, including FFmpeg.wasm, Astro, and Tailwind CSS. All trademarks remain the property of their respective owners.</p>
    
    </div>
  </div>
</Layout>
