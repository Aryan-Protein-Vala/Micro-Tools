---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';
---

<Layout title="Free Online Audio Converter | Convert WAV, OGG, Video to MP3" description="Convert audio files to MP3, WAV, and OGG formats instantly online. Free browser-based audio converter — no uploads, no software install. Convert video to audio, WAV to MP3, and more." keywords="audio converter online, convert wav to mp3, free audio converter, video to mp3 converter, ogg to mp3, online mp3 converter, convert audio files free, wav to mp3 online, audio format converter, extract audio from video online">
  <ToolWorkspace title="Audio Converter" toolName="audio-converter" hasContextPanel={true}>
    
    <!-- Controls Slot -->
    <Fragment slot="controls">
      <div class="space-y-4">
        <p class="text-sm text-muted-foreground">Convert WAV, OGG, or Video audio tracks directly to standard MP3.</p>

        <div class="space-y-2">
          <label class="text-sm font-medium">MP3 Bitrate</label>
          <select id="bitrate-select" class="w-full p-2 bg-black/40 border border-border rounded text-sm text-foreground focus:outline-none focus:border-accent">
            <option value="64">64 kbps (Voice / Smallest)</option>
            <option value="128" selected>128 kbps (Standard Quality)</option>
            <option value="192">192 kbps (High Quality)</option>
            <option value="320">320 kbps (Studio Quality)</option>
          </select>
        </div>

        <div class="pt-4 space-y-2 border-t border-border">
          <button id="btn-process" disabled class="w-full px-4 py-2 bg-accent text-background text-sm font-medium rounded-md hover:bg-accent/90 transition-smooth disabled:opacity-50 disabled:cursor-not-allowed">
            Convert to MP3
          </button>
          
          <a id="btn-download" class="w-full px-4 py-2 bg-green-500 text-background text-sm font-medium rounded-md hover:bg-green-600 transition-smooth hidden items-center justify-center gap-2 cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download MP3
          </a>
          
          <button id="btn-reset" class="w-full px-4 py-2 bg-muted/20 hover:bg-muted/30 text-foreground text-sm rounded-md transition-smooth">
            Start Over
          </button>
        </div>
      </div>
    </Fragment>

    <!-- Main Stage -->
    <div class="h-full flex flex-col gap-6">
      <div class="text-center">
        <h2 class="text-2xl font-bold mb-2">Web Audio Converter</h2>
        <p class="text-muted-foreground text-sm">Offline audio encoding. Your files never touch a server.</p>
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <!-- Dropzone -->
        <div id="audio-dropzone" class="flex-1 border-2 border-dashed border-border rounded-xl flex flex-col items-center justify-center p-8 text-center cursor-pointer hover:border-accent hover:bg-accent/5 transition-smooth bg-black/20 min-h-[300px]">
          <div class="text-4xl mb-4 opacity-80">🎵</div>
          <h3 class="text-xl font-bold mb-2">Drop your Audio/Video file here</h3>
          <p class="text-sm text-muted-foreground">WAV, OGG, MP4, WEBM</p>
          <input type="file" id="audio-file-input" accept="audio/*,video/*" class="hidden" />
        </div>

        <!-- Preview & Progress -->
        <div id="preview-container" class="hidden flex-1 flex flex-col gap-6 items-center justify-center min-h-[300px]">
          <audio id="audio-preview" controls class="w-full max-w-md"></audio>
          
          <div class="w-full max-w-md">
            <p id="audio-status" class="hidden text-sm font-mono text-center mb-2 text-muted-foreground"></p>
            <div id="progress-container" class="hidden w-full bg-muted/20 rounded-full h-2 overflow-hidden">
              <div id="progress-bar-fill" class="bg-accent h-2 rounded-full" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </ToolWorkspace>
</Layout>

<script>
  import { setupUI } from '../../scripts/audio-engine.js';
  
  document.addEventListener('astro:page-load', setupUI);
  document.addEventListener('DOMContentLoaded', setupUI);
</script>
