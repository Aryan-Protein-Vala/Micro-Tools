---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';
---

<Layout title="JSON to Clean Table Visualizer - ToolGrid">
  <ToolWorkspace title="JSON Visualizer" toolName="json-visualizer" hasContextPanel={true}>
    
    <!-- Controls Slot -->
    <Fragment slot="controls">
      <div class="space-y-3">
        <button id="btn-export-csv-side" class="w-full px-4 py-2 bg-accent text-background text-sm font-medium rounded-md hover:bg-accent/90 transition-smooth hidden">
          Export CSV
        </button>
        <button id="btn-reset" class="w-full px-4 py-2 bg-muted/20 hover:bg-muted/30 text-foreground text-sm rounded-md transition-smooth">
          Clear Data
        </button>
      </div>
    </Fragment>

    <!-- Main Stage -->
    <div class="flex flex-col gap-6 h-full">
      <div class="text-center">
        <h2 class="text-2xl font-bold mb-2">JSON to Table Visualizer</h2>
        <p class="text-muted-foreground text-sm">Instantly transform dense API payloads into readable tables.</p>
      </div>

      <div id="input-section" class="flex flex-col gap-4 flex-1">
        <div class="bg-black/40 border border-border rounded-lg overflow-hidden flex flex-col h-[400px]">
          <div class="flex items-center gap-2 p-3 border-b border-border bg-muted/10">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="text-xs font-mono text-muted-foreground ml-2">input.json</span>
          </div>
          <textarea 
            id="json-input" 
            class="flex-1 w-full p-4 bg-transparent text-sm font-mono text-foreground focus:outline-none resize-none"
            placeholder='[\n  {\n    "id": 1,\n    "name": "Jane Doe",\n    "metadata": {\n      "role": "Admin",\n      "active": true\n    }\n  }\n]'
          ></textarea>
        </div>
        
        <div class="flex justify-end">
          <button id="btn-visualize" class="px-6 py-2 bg-accent text-background font-medium rounded-full hover:bg-accent/90 transition-smooth">
            Flatten & Visualize
          </button>
        </div>

        <div id="error-container" class="hidden bg-red-500/10 text-red-400 p-4 rounded-md border border-red-500/20 text-sm font-medium flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <span id="error-message">Invalid JSON.</span>
        </div>
      </div>

      <!-- Output Table Container -->
      <div id="table-container" class="hidden flex-col gap-4">
        <div class="flex items-center justify-between">
          <h3 class="font-bold text-lg">Flattened Data <span id="row-count" class="text-sm font-normal text-muted-foreground ml-2"></span></h3>
          <!-- Hidden original export button, trigger via side button -->
          <button id="btn-export-csv" class="hidden"></button>
        </div>
        
        <div class="bg-black/40 border border-border rounded-lg overflow-x-auto max-h-[500px]">
          <table class="w-full text-left text-sm" id="data-table">
            <thead class="bg-muted/20 text-muted-foreground sticky top-0">
              <tr id="table-head-row">
                <!-- Headers populated via JS -->
              </tr>
            </thead>
            <tbody id="table-body" class="divide-y divide-border">
              <!-- Rows populated via JS -->
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </ToolWorkspace>
</Layout>

<script>
  import { setupUI } from '../../scripts/json-engine.js';
  
  function initVisualizer() {
    setupUI();
    
    const resetBtn = document.getElementById('btn-reset');
    const inputSection = document.getElementById('input-section');
    const tableContainer = document.getElementById('table-container');
    const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
    const exportBtnSide = document.getElementById('btn-export-csv-side');
    const exportBtnMain = document.getElementById('btn-export-csv');
    
    // Show side export button when main table container is visible
    const observer = new MutationObserver(() => {
      if (!tableContainer?.classList.contains('hidden')) {
        exportBtnSide?.classList.remove('hidden');
        inputSection?.classList.add('hidden');
      }
    });

    if (tableContainer) {
      observer.observe(tableContainer, { attributes: true, attributeFilter: ['class'] });
    }

    exportBtnSide?.addEventListener('click', () => {
      exportBtnMain?.click();
    });

    resetBtn?.addEventListener('click', () => {
      if (jsonInput) jsonInput.value = '';
      tableContainer?.classList.add('hidden');
      exportBtnSide?.classList.add('hidden');
      inputSection?.classList.remove('hidden');
      const errorContainer = document.getElementById('error-container');
      if (errorContainer) errorContainer.classList.add('hidden');
    });
  }

  document.addEventListener('astro:page-load', initVisualizer);
  document.addEventListener('DOMContentLoaded', initVisualizer);
</script>
