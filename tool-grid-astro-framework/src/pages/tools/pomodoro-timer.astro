---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';
---

<Layout 
  title="Free Pomodoro Timer Online | Focus Timer & Productivity Tracker" 
  description="Boost your productivity with our free online Pomodoro timer. Customizable work sessions, short breaks, and long breaks with audio alerts. Track completed sessions and stay focused — no signup required."
  keywords="pomodoro timer, pomodoro timer online, free pomodoro, focus timer, productivity timer, study timer online, work timer, 25 minute timer, pomodoro technique, tomato timer, focus timer online free, concentration timer"
>
  <ToolWorkspace title="Pomodoro Timer" toolName="pomodoro-timer" hasContextPanel={true}>
    <div class="max-w-lg mx-auto space-y-6" id="pomo-app">
      <!-- Mode Tabs -->
      <div class="flex rounded-lg overflow-hidden border border-border">
        <button class="pomo-tab flex-1 py-3 text-sm font-bold uppercase tracking-wider bg-white/10 text-white cursor-pointer transition-colors" data-mode="work">Focus</button>
        <button class="pomo-tab flex-1 py-3 text-sm font-bold uppercase tracking-wider bg-black/40 text-muted-foreground cursor-pointer hover:bg-white/5 transition-colors" data-mode="short">Short Break</button>
        <button class="pomo-tab flex-1 py-3 text-sm font-bold uppercase tracking-wider bg-black/40 text-muted-foreground cursor-pointer hover:bg-white/5 transition-colors" data-mode="long">Long Break</button>
      </div>

      <!-- Timer Display -->
      <div class="bg-black/40 border border-border rounded-2xl p-12 text-center">
        <p id="pomo-time" class="text-7xl sm:text-8xl font-mono font-bold text-white tracking-wider tabular-nums">25:00</p>
        <p id="pomo-label" class="text-sm text-muted-foreground mt-4 uppercase tracking-widest">Focus Session</p>
      </div>

      <!-- Controls -->
      <div class="flex items-center justify-center gap-4">
        <button id="pomo-reset" class="px-6 py-3 bg-white/5 hover:bg-white/10 text-white/70 text-sm font-bold rounded-lg transition-colors cursor-pointer border border-border">Reset</button>
        <button id="pomo-start" class="px-10 py-3 bg-white text-black text-sm font-bold rounded-lg hover:bg-white/90 transition-colors cursor-pointer tracking-wider uppercase">Start</button>
        <button id="pomo-skip" class="px-6 py-3 bg-white/5 hover:bg-white/10 text-white/70 text-sm font-bold rounded-lg transition-colors cursor-pointer border border-border">Skip</button>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-black/40 border border-border rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-white" id="pomo-completed">0</p>
          <p class="text-xs text-muted-foreground mt-1">Sessions</p>
        </div>
        <div class="bg-black/40 border border-border rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-white" id="pomo-total-time">0m</p>
          <p class="text-xs text-muted-foreground mt-1">Focus Time</p>
        </div>
        <div class="bg-black/40 border border-border rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-white" id="pomo-streak">0</p>
          <p class="text-xs text-muted-foreground mt-1">Streak</p>
        </div>
      </div>

      <!-- Settings -->
      <div class="bg-black/40 border border-border rounded-lg p-6 space-y-4">
        <h3 class="text-sm font-bold text-white">Customize Durations</h3>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="text-xs text-muted-foreground block mb-1">Focus (min)</label>
            <input type="number" id="pomo-work-min" value="25" min="1" max="120" class="w-full px-3 py-2 bg-black/40 border border-border rounded-lg text-white text-sm font-mono focus:outline-none focus:border-white/30" />
          </div>
          <div>
            <label class="text-xs text-muted-foreground block mb-1">Short Break</label>
            <input type="number" id="pomo-short-min" value="5" min="1" max="30" class="w-full px-3 py-2 bg-black/40 border border-border rounded-lg text-white text-sm font-mono focus:outline-none focus:border-white/30" />
          </div>
          <div>
            <label class="text-xs text-muted-foreground block mb-1">Long Break</label>
            <input type="number" id="pomo-long-min" value="15" min="1" max="60" class="w-full px-3 py-2 bg-black/40 border border-border rounded-lg text-white text-sm font-mono focus:outline-none focus:border-white/30" />
          </div>
        </div>
      </div>
    </div>
  </ToolWorkspace>
</Layout>

<script is:inline>
  let mode = 'work';
  let durations = { work: 25 * 60, short: 5 * 60, long: 15 * 60 };
  let timeLeft = durations.work;
  let running = false;
  let interval = null;
  let completed = 0;
  let totalFocusSeconds = 0;
  let streak = 0;

  const timeEl = document.getElementById('pomo-time');
  const labelEl = document.getElementById('pomo-label');
  const startBtn = document.getElementById('pomo-start');
  const resetBtn = document.getElementById('pomo-reset');
  const skipBtn = document.getElementById('pomo-skip');
  const completedEl = document.getElementById('pomo-completed');
  const totalTimeEl = document.getElementById('pomo-total-time');
  const streakEl = document.getElementById('pomo-streak');

  function formatTime(s) {
    const m = Math.floor(s / 60).toString().padStart(2, '0');
    const sec = (s % 60).toString().padStart(2, '0');
    return `${m}:${sec}`;
  }

  function updateDisplay() {
    timeEl.textContent = formatTime(timeLeft);
    const labels = { work: 'Focus Session', short: 'Short Break', long: 'Long Break' };
    labelEl.textContent = labels[mode];
    document.title = `${formatTime(timeLeft)} — ${labels[mode]} | ToolGrid`;
  }

  function playBeep() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.frequency.value = 800;
      gain.gain.value = 0.3;
      osc.start();
      osc.stop(ctx.currentTime + 0.3);
      setTimeout(() => {
        const osc2 = ctx.createOscillator();
        osc2.connect(gain);
        osc2.frequency.value = 1000;
        osc2.start();
        osc2.stop(ctx.currentTime + 0.3);
      }, 400);
    } catch(e) {}
  }

  function tick() {
    if (timeLeft <= 0) {
      clearInterval(interval);
      running = false;
      startBtn.textContent = 'Start';
      playBeep();

      if (mode === 'work') {
        completed++;
        totalFocusSeconds += durations.work;
        streak++;
        completedEl.textContent = completed;
        totalTimeEl.textContent = Math.round(totalFocusSeconds / 60) + 'm';
        streakEl.textContent = streak;
        // Auto switch to break
        mode = completed % 4 === 0 ? 'long' : 'short';
      } else {
        mode = 'work';
      }
      timeLeft = durations[mode];
      updateTabs();
      updateDisplay();
      return;
    }
    timeLeft--;
    if (mode === 'work') totalFocusSeconds++;
    updateDisplay();
  }

  function updateTabs() {
    document.querySelectorAll('.pomo-tab').forEach(tab => {
      if (tab.dataset.mode === mode) {
        tab.classList.add('bg-white/10', 'text-white');
        tab.classList.remove('bg-black/40', 'text-muted-foreground');
      } else {
        tab.classList.remove('bg-white/10', 'text-white');
        tab.classList.add('bg-black/40', 'text-muted-foreground');
      }
    });
  }

  startBtn.addEventListener('click', () => {
    if (running) {
      clearInterval(interval);
      running = false;
      startBtn.textContent = 'Start';
    } else {
      interval = setInterval(tick, 1000);
      running = true;
      startBtn.textContent = 'Pause';
    }
  });

  resetBtn.addEventListener('click', () => {
    clearInterval(interval);
    running = false;
    startBtn.textContent = 'Start';
    timeLeft = durations[mode];
    updateDisplay();
  });

  skipBtn.addEventListener('click', () => {
    clearInterval(interval);
    running = false;
    startBtn.textContent = 'Start';
    if (mode === 'work') {
      mode = completed % 4 === 0 ? 'long' : 'short';
    } else {
      mode = 'work';
    }
    timeLeft = durations[mode];
    updateTabs();
    updateDisplay();
  });

  document.querySelectorAll('.pomo-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      clearInterval(interval);
      running = false;
      startBtn.textContent = 'Start';
      mode = tab.dataset.mode;
      timeLeft = durations[mode];
      updateTabs();
      updateDisplay();
    });
  });

  // Settings
  ['pomo-work-min', 'pomo-short-min', 'pomo-long-min'].forEach((id, i) => {
    const el = document.getElementById(id);
    el.addEventListener('change', () => {
      const keys = ['work', 'short', 'long'];
      durations[keys[i]] = parseInt(el.value) * 60;
      if (mode === keys[i] && !running) {
        timeLeft = durations[keys[i]];
        updateDisplay();
      }
    });
  });

  updateDisplay();
</script>
