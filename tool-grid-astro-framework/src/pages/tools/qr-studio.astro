---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';
---

<Layout title="Free QR Code Generator & Scanner Online | No Signup Required" description="Generate and scan QR codes instantly in your browser. Free online QR code maker with no watermarks, no tracking, and no uploads. Create QR codes for URLs, text, WiFi, and more." keywords="free qr code generator, qr code generator online, create qr code free, qr code scanner online, qr code maker, generate qr code, scan qr code from image, wifi qr code generator, bulk qr code generator, no watermark qr code">
  <ToolWorkspace
    title="Zero-Trust QR Studio"
    description="Generate permanent QR codes or scan them securely without leaving your browser. 100% private, zero tracking."
    icon="M3 3h6v6H3zM15 3h6v6h-6zM3 15h6v6H3zM13 13h1.5v1.5H13zM15 15h1.5v1.5H15zM17 13h1.5v1.5H17zM19 15h1.5v1.5H19z"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Controls Column -->
      <div class="space-y-6">
        
        <!-- Mode Toggle -->
        <div class="flex p-1 bg-white/5 border border-white/10 rounded-xl" role="tablist">
          <button id="tab-generator" class="flex-1 py-2 text-sm font-medium rounded-lg bg-white/10 text-white shadow-sm transition-all" role="tab" aria-selected="true">Generator</button>
          <button id="tab-scanner" class="flex-1 py-2 text-sm font-medium rounded-lg text-white/50 hover:text-white transition-all" role="tab" aria-selected="false">Scanner</button>
        </div>

        <!-- Generator Controls -->
        <div id="generator-view" class="space-y-4 transition-opacity duration-300">
          <div>
            <label class="block text-sm font-medium text-white/70 mb-2">Text or URL to Encode</label>
            <textarea
              id="qr-input"
              rows="4"
              class="w-full px-4 py-3 bg-black/50 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-all font-mono text-sm resize-none"
              placeholder="https://example.com"
            ></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-white/70 mb-2">Foreground Color</label>
              <input type="color" id="color-dark" value="#ffffff" class="w-full h-10 rounded-lg cursor-pointer bg-transparent border-0" />
            </div>
            <div>
              <label class="block text-sm font-medium text-white/70 mb-2">Background Color</label>
              <input type="color" id="color-light" value="#000000" class="w-full h-10 rounded-lg cursor-pointer bg-transparent border-0" />
            </div>
          </div>

          <button
            id="btn-generate"
            class="w-full py-4 px-6 bg-white text-black font-semibold rounded-xl hover:bg-white/90 transition-all flex items-center justify-center gap-2 group"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:scale-110 transition-transform"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Generate QR Code
          </button>
        </div>

        <!-- Scanner Controls -->
        <div id="scanner-view" class="space-y-4 hidden opacity-0 transition-opacity duration-300">
          <div class="flex flex-col gap-4">
            <button
              id="btn-start-camera"
              class="w-full py-4 px-6 bg-white/10 text-white font-semibold rounded-xl border border-white/10 hover:bg-white/20 transition-all flex items-center justify-center gap-2 group"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              Start Web Camera
            </button>
            <button
              id="btn-stop-camera"
              class="w-full py-3 px-6 bg-red-500/10 text-red-400 font-medium rounded-xl border border-red-500/20 hover:bg-red-500/20 hidden transition-all flex items-center justify-center gap-2"
            >
              Stop Camera
            </button>
            
            <div class="relative group">
              <input
                type="file"
                id="qr-file"
                accept="image/*"
                class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
              />
              <div class="w-full py-4 px-6 bg-black/50 border border-white/10 border-dashed rounded-xl flex items-center justify-center gap-2 text-white/50 group-hover:text-white/80 group-hover:border-white/30 transition-all">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <span>Or upload QR Image</span>
              </div>
            </div>
          </div>
          
          <!-- Scanner Result -->
          <div id="scanner-result-box" class="hidden mt-4 p-4 bg-white/5 border border-white/10 rounded-xl">
            <h3 class="text-sm font-medium text-white/70 mb-2">Decoded Content</h3>
            <textarea
              id="scanner-output"
              readonly
              rows="3"
              class="w-full px-4 py-3 bg-black/50 border border-white/10 rounded-lg text-green-400 font-mono text-sm resize-none focus:outline-none"
            ></textarea>
            <button
              id="btn-copy-result"
              class="mt-2 w-full py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg transition-all text-sm font-medium"
            >
              Copy Content
            </button>
          </div>
        </div>
      </div>

      <!-- Preview Column -->
      <div class="relative bg-black/50 rounded-2xl border border-white/10 flex items-center justify-center p-8 overflow-hidden min-h-[400px]">
        
        <!-- Generator Canvas Wrapper -->
        <div id="canvas-wrapper" class="relative z-10 w-full aspect-square max-w-[300px] flex items-center justify-center bg-transparent rounded-xl">
          <canvas id="qr-canvas" class="hidden max-w-full rounded-lg shadow-2xl"></canvas>
          <div id="empty-state" class="text-center">
            <div class="w-24 h-24 mx-auto mb-4 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/20"><path d="M3 3h6v6H3zM15 3h6v6h-6zM3 15h6v6H3zM13 13h1.5v1.5H13zM15 15h1.5v1.5H15zM17 13h1.5v1.5H17zM19 15h1.5v1.5H19z"/></svg>
            </div>
            <p class="text-sm text-white/40">Enter text to generate QR</p>
          </div>
        </div>

        <!-- Scanner Video Wrapper -->
        <div id="scanner-wrapper" class="hidden absolute inset-0 bg-black z-20 flex flex-col items-center justify-center">
          <div id="qr-reader" class="w-full max-w-[400px]"></div>
        </div>

        <!-- Download Overlay (Generator) -->
        <div id="download-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm z-30 hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300">
          <div class="bg-white/10 p-4 rounded-full mb-4">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">QR Code Generated</h3>
          <p class="text-white/60 mb-6 max-w-xs text-center">100% static. No tracking, no expiration.</p>
          <button
            id="btn-download"
            class="py-3 px-8 bg-white text-black font-semibold rounded-xl hover:bg-white/90 transition-all shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:shadow-[0_0_60px_rgba(255,255,255,0.5)] flex items-center gap-2"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download PNG
          </button>
          <button id="btn-reset" class="mt-4 text-sm text-white/50 hover:text-white transition-colors">Create Another</button>
        </div>
      </div>

    </div>
  </ToolWorkspace>
</Layout>

<script>
  import { setupUI } from '../../scripts/qr-engine.js';
  
  document.addEventListener('astro:page-load', setupUI);
  document.addEventListener('DOMContentLoaded', setupUI);
</script>
