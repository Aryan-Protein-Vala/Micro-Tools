---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';
---

<Layout title="Free Secure Image-to-Text OCR - ToolGrid">
  <ToolWorkspace title="Image-to-Text OCR" toolName="ocr-converter" hasContextPanel={true}>
    
    <!-- Controls Slot -->
    <Fragment slot="controls">
      <div class="space-y-4">
        <p class="text-sm text-muted-foreground">Extract text from documents securely using Tesseract WASM. No images are uploaded to any server.</p>

        <div class="pt-4 space-y-2 border-t border-border">
          <button id="btn-process" disabled class="w-full px-4 py-2 bg-accent text-background text-sm font-medium rounded-md hover:bg-accent/90 transition-smooth disabled:opacity-50 disabled:cursor-not-allowed">
            Extract Text
          </button>
          
          <button id="btn-copy" class="w-full px-4 py-2 bg-green-500 text-background text-sm font-medium rounded-md hover:bg-green-600 transition-smooth hidden items-center justify-center gap-2 cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            Copy to Clipboard
          </button>
          
          <button id="btn-reset" class="w-full px-4 py-2 bg-muted/20 hover:bg-muted/30 text-foreground text-sm rounded-md transition-smooth">
            Start Over
          </button>
        </div>
      </div>
    </Fragment>

    <!-- Main Stage -->
    <div class="h-full flex flex-col gap-6">
      <div class="text-center">
        <h2 class="text-2xl font-bold mb-2">Secure Image-to-Text Converter</h2>
        <p class="text-muted-foreground text-sm">Convert photos, screenshots, and scans into editable text instantly.</p>
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <!-- Dropzone -->
        <div id="image-dropzone" class="flex-1 border-2 border-dashed border-border rounded-xl flex flex-col items-center justify-center p-8 text-center cursor-pointer hover:border-accent hover:bg-accent/5 transition-smooth bg-black/20 min-h-[200px]">
          <div class="text-4xl mb-4 opacity-80">📄</div>
          <h3 class="text-xl font-bold mb-2">Drop your image here</h3>
          <p class="text-sm text-muted-foreground">Supports JPG, PNG, WEBP, BMP</p>
          <input type="file" id="image-file-input" accept="image/*" class="hidden" />
        </div>

        <!-- Preview & Progress -->
        <div id="preview-container" class="hidden flex-1 flex flex-col gap-4">
          <p id="ocr-status" class="hidden text-sm font-mono text-center text-muted-foreground"></p>
          
          <div id="progress-container" class="hidden w-full bg-muted/20 rounded-full h-2 overflow-hidden">
            <div id="progress-bar-fill" class="bg-accent h-2 rounded-full" style="width: 0%"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 flex-1 min-h-[400px]">
            <div class="bg-black/40 border border-border rounded-lg overflow-hidden flex flex-col relative bg-muted/10 p-2">
              <span class="absolute top-2 left-2 bg-black/80 px-2 py-1 rounded text-xs text-white z-10">Image Source</span>
              <img id="original-preview" class="w-full h-full object-contain" />
            </div>
            
            <div class="bg-black/40 border border-border rounded-lg overflow-hidden flex flex-col relative">
              <div class="flex items-center gap-2 p-3 border-b border-border bg-muted/10">
                <span class="text-xs font-mono text-muted-foreground">output.txt</span>
              </div>
              <textarea id="ocr-output" class="w-full h-full p-4 bg-transparent resize-none focus:outline-none text-sm text-foreground font-mono" placeholder="Extracted text will appear here..."></textarea>
            </div>
          </div>
        </div>
      </div>
    </div>

  </ToolWorkspace>
</Layout>

<script>
  import { setupUI } from '../../scripts/ocr-engine.js';
  
  document.addEventListener('DOMContentLoaded', () => {
    setupUI();
  });
</script>
