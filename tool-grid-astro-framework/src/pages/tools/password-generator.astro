---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';

const faqs = [
  {
    question: "Is this Password Generator completely free to use?",
    answer: "Yes, our Password Generator is 100% free with no hidden limits, watermarks, or premium subscriptions required."
  },
  {
    question: "Is my data secure when using the Password Generator?",
    answer: "Absolutely. We use a Zero-Trust architecture, meaning all processing happens locally inside your web browser. Your files are never uploaded to our servers, ensuring total privacy and security."
  },
  {
    question: "Do I need to install any software?",
    answer: "No installation is required! This is a web-based Password Generator that runs perfectly in any modern browser on both desktop and mobile devices."
  }
];
---

<Layout 
  title="Free Strong Password Generator Online | Secure Random Passwords" 
  description="Generate strong, secure random passwords instantly. Free online password generator with customizable length, special characters, numbers, and uppercase letters. All passwords are generated locally — nothing is stored or transmitted."
  keywords="password generator, strong password generator, random password generator, secure password generator, free password generator, generate password online, password creator, strong password maker, random password online, password generator no tracking"

  schemaType="SoftwareApplication"
  applicationCategory="UtilitiesApplication"
  faqs={faqs}
>
  <ToolWorkspace title="Password Generator" toolName="password-generator" hasContextPanel={true} faqs={faqs}>
    <div class="max-w-2xl mx-auto space-y-6" id="pw-app">
      <!-- Generated Password Display -->
      <div class="bg-black/60 border border-border rounded-lg p-6">
        <div class="flex items-center gap-3">
          <p id="pw-output" class="flex-1 text-xl sm:text-2xl font-mono text-white break-all select-all tracking-wide">Click Generate</p>
          <button id="pw-copy" class="shrink-0 px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-bold rounded-lg transition-colors cursor-pointer">Copy</button>
        </div>
        <div class="mt-3 flex items-center gap-2">
          <div class="flex-1 h-2 bg-black/40 rounded-full overflow-hidden">
            <div id="pw-strength-bar" class="h-full rounded-full transition-all duration-300 bg-red-500" style="width: 0%"></div>
          </div>
          <span id="pw-strength-label" class="text-xs text-muted-foreground font-bold">—</span>
        </div>
      </div>

      <!-- Controls -->
      <div class="bg-black/40 border border-border rounded-lg p-6 space-y-5">
        <!-- Length -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-sm font-bold text-white">Password Length</label>
            <span id="pw-length-display" class="text-sm font-mono text-accent">16</span>
          </div>
          <input type="range" id="pw-length" min="4" max="64" value="16" class="w-full h-2 bg-white/10 rounded-full appearance-none cursor-pointer" />
        </div>

        <!-- Options -->
        <div class="grid grid-cols-2 gap-4">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="pw-upper" checked class="w-4 h-4 rounded accent-white cursor-pointer" />
            <span class="text-sm text-white/80">Uppercase (A-Z)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="pw-lower" checked class="w-4 h-4 rounded accent-white cursor-pointer" />
            <span class="text-sm text-white/80">Lowercase (a-z)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="pw-numbers" checked class="w-4 h-4 rounded accent-white cursor-pointer" />
            <span class="text-sm text-white/80">Numbers (0-9)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="pw-symbols" checked class="w-4 h-4 rounded accent-white cursor-pointer" />
            <span class="text-sm text-white/80">Symbols (!@#$)</span>
          </label>
        </div>

        <!-- Generate Button -->
        <button id="pw-generate" class="w-full py-3 bg-white text-black font-bold rounded-lg hover:bg-white/90 transition-colors cursor-pointer text-sm tracking-wider uppercase">
          Generate Password
        </button>
      </div>

      <!-- Bulk Generate -->
      <div class="bg-black/40 border border-border rounded-lg p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-bold text-white">Bulk Generate</h3>
          <button id="pw-bulk-copy" class="text-xs text-accent hover:underline cursor-pointer">Copy All</button>
        </div>
        <div id="pw-bulk-list" class="space-y-1 font-mono text-sm text-white/70 max-h-40 overflow-y-auto">
          <p class="text-xs text-muted-foreground">Click generate to create multiple passwords...</p>
        </div>
      </div>
    </div>
  </ToolWorkspace>
</Layout>

<script is:inline>
  const output = document.getElementById('pw-output');
  const lengthSlider = document.getElementById('pw-length');
  const lengthDisplay = document.getElementById('pw-length-display');
  const genBtn = document.getElementById('pw-generate');
  const copyBtn = document.getElementById('pw-copy');
  const bulkList = document.getElementById('pw-bulk-list');
  const bulkCopyBtn = document.getElementById('pw-bulk-copy');
  const strengthBar = document.getElementById('pw-strength-bar');
  const strengthLabel = document.getElementById('pw-strength-label');

  const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghijklmnopqrstuvwxyz';
  const NUMBERS = '0123456789';
  const SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';

  lengthSlider.addEventListener('input', () => {
    lengthDisplay.textContent = lengthSlider.value;
  });

  function generatePassword() {
    let charset = '';
    if (document.getElementById('pw-upper').checked) charset += UPPER;
    if (document.getElementById('pw-lower').checked) charset += LOWER;
    if (document.getElementById('pw-numbers').checked) charset += NUMBERS;
    if (document.getElementById('pw-symbols').checked) charset += SYMBOLS;
    if (!charset) charset = LOWER;

    const len = parseInt(lengthSlider.value);
    const array = new Uint32Array(len);
    crypto.getRandomValues(array);
    let pw = '';
    for (let i = 0; i < len; i++) {
      pw += charset[array[i] % charset.length];
    }
    return pw;
  }

  function updateStrength(pw) {
    let score = 0;
    if (pw.length >= 8) score++;
    if (pw.length >= 12) score++;
    if (pw.length >= 20) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[a-z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;

    const pct = Math.min(100, (score / 7) * 100);
    strengthBar.style.width = pct + '%';
    if (pct < 40) { strengthBar.className = 'h-full rounded-full transition-all duration-300 bg-red-500'; strengthLabel.textContent = 'Weak'; }
    else if (pct < 70) { strengthBar.className = 'h-full rounded-full transition-all duration-300 bg-yellow-500'; strengthLabel.textContent = 'Fair'; }
    else if (pct < 90) { strengthBar.className = 'h-full rounded-full transition-all duration-300 bg-blue-400'; strengthLabel.textContent = 'Strong'; }
    else { strengthBar.className = 'h-full rounded-full transition-all duration-300 bg-green-400'; strengthLabel.textContent = 'Very Strong'; }
  }

  genBtn.addEventListener('click', () => {
    const pw = generatePassword();
    output.textContent = pw;
    updateStrength(pw);

    // Bulk generate 5
    const bulkPws = [];
    for (let i = 0; i < 5; i++) bulkPws.push(generatePassword());
    bulkList.innerHTML = bulkPws.map(p => `<p class="py-1 border-b border-border/30 select-all">${p}</p>`).join('');
  });

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(output.textContent);
    copyBtn.textContent = 'Copied!';
    setTimeout(() => copyBtn.textContent = 'Copy', 1500);
  });

  bulkCopyBtn.addEventListener('click', () => {
    const all = Array.from(bulkList.querySelectorAll('p')).map(p => p.textContent).join('\n');
    navigator.clipboard.writeText(all);
    bulkCopyBtn.textContent = 'Copied!';
    setTimeout(() => bulkCopyBtn.textContent = 'Copy All', 1500);
  });

  // Auto-generate on load
  genBtn.click();
</script>
