---
import Layout from '../../layouts/Layout.astro';
import ToolWorkspace from '../../components/ToolWorkspace.astro';
---

<Layout title="Free Batch Image Vectorizer - ToolGrid" description="Free Image Vectorizer. Convert raster images (PNG, JPG) to scalable vector graphics (SVG) instantly with local WASM tracing.">
  <ToolWorkspace title="Image Vectorizer" toolName="image-vectorizer" hasContextPanel={true}>
    
    <!-- Controls Slot -->
    <Fragment slot="controls">
      <div class="space-y-4">
        <p class="text-sm text-muted-foreground">Convert raster images (PNG/JPG) to scalable vector graphics (SVG) locally.</p>

        <div class="space-y-2">
          <label class="text-sm font-medium">Tracing Preset</label>
          <select id="preset-select" class="w-full p-2 bg-black/40 border border-border rounded text-sm text-foreground focus:outline-none focus:border-accent">
            <option value="default">Default / Balanced</option>
            <option value="posterized2">Posterized (Simple)</option>
            <option value="posterized3">Posterized (Detailed)</option>
            <option value="curvy">Curvy / Smooth</option>
            <option value="sharp">Sharp Edges (Logos)</option>
            <option value="detailed">High Detail</option>
            <option value="artistic">Artistic / Painting</option>
          </select>
        </div>

        <div class="pt-4 space-y-2 border-t border-border">
          <button id="btn-process" disabled class="w-full px-4 py-2 bg-accent text-background text-sm font-medium rounded-md hover:bg-accent/90 transition-smooth disabled:opacity-50 disabled:cursor-not-allowed">
            Vectorize Image
          </button>
          
          <button id="btn-download" class="w-full px-4 py-2 bg-green-500 text-background text-sm font-medium rounded-md hover:bg-green-600 transition-smooth hidden items-center justify-center gap-2 cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download SVG
          </button>
          
          <button id="btn-reset" class="w-full px-4 py-2 bg-muted/20 hover:bg-muted/30 text-foreground text-sm rounded-md transition-smooth">
            Start Over
          </button>
        </div>
      </div>
    </Fragment>

    <!-- Main Stage -->
    <div class="h-full flex flex-col gap-6">
      <div class="text-center">
        <h2 class="text-2xl font-bold mb-2">PNG/JPG to SVG Vectorizer</h2>
        <p class="text-muted-foreground text-sm">Turn low-res logos and art into infinitely scalable SVG vectors.</p>
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <!-- Dropzone -->
        <div id="image-dropzone" class="flex-1 border-2 border-dashed border-border rounded-xl flex flex-col items-center justify-center p-8 text-center cursor-pointer hover:border-accent hover:bg-accent/5 transition-smooth bg-black/20 min-h-[300px]">
          <div class="text-4xl mb-4 opacity-80">🎨</div>
          <h3 class="text-xl font-bold mb-2">Drop your raster image here</h3>
          <p class="text-sm text-muted-foreground">PNG, JPG, or WEBP</p>
          <input type="file" id="image-file-input" accept="image/*" class="hidden" />
        </div>

        <!-- Preview -->
        <div id="preview-container" class="hidden flex-1 grid grid-cols-2 gap-4 h-full min-h-[400px]">
          <div class="bg-black/40 border border-border rounded-lg overflow-hidden flex flex-col relative bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+CjxyZWN0IHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCIgZmlsbD0iIzIyMiIvPgo8cmVjdCB3aWR0aD0iMTAiIGhlaWdodD0iMTAiIGZpbGw9IiMzMzMiLz4KPHJlY3QgeD0iMTAiIHk9IjEwIiB3aWR0aD0iMTAiIGhlaWdodD0iMTAiIGZpbGw9IiMzMzMiLz4KPC9zdmc+')]">
            <span class="absolute top-2 left-2 bg-black/80 px-2 py-1 rounded text-xs text-white z-10">Original Raster</span>
            <img id="original-preview" class="w-full h-full object-contain" />
          </div>
          
          <div class="bg-black/40 border border-border rounded-lg overflow-hidden flex flex-col relative bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+CjxyZWN0IHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCIgZmlsbD0iIzIyMiIvPgo8cmVjdCB3aWR0aD0iMTAiIGhlaWdodD0iMTAiIGZpbGw9IiMzMzMiLz4KPHJlY3QgeD0iMTAiIHk9IjEwIiB3aWR0aD0iMTAiIGhlaWdodD0iMTAiIGZpbGw9IiMzMzMiLz4KPC9zdmc+')]">
            <span class="absolute top-2 left-2 bg-black/80 px-2 py-1 rounded text-xs text-white z-10">Vectorized SVG</span>
            <div id="svg-preview-container" class="w-full h-full flex items-center justify-center p-4"></div>
          </div>
        </div>
      </div>
    </div>

  </ToolWorkspace>
</Layout>

<script>
  import { setupUI } from '../../scripts/vector-engine.js';
  
  document.addEventListener('astro:page-load', setupUI);
  document.addEventListener('DOMContentLoaded', setupUI);
</script>
