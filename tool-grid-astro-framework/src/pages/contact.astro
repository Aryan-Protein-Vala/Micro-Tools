---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | ToolGrid" description="Get in touch with the ToolGrid team for support, feedback, or business inquiries.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl py-20">
    <div class="prose prose-invert prose-lg max-w-none">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">Contact Us</h1>
      
      <p class="text-muted-foreground mb-6">We'd love to hear from you. Whether you have a feature request, found a bug, or just want to say hi, feel free to reach out directly.</p>
      <div class="p-6 bg-accent/10 border border-border rounded-lg inline-block">
        <h3 class="text-lg font-medium mb-2">Direct Email</h3>
        <a href="mailto:aryansharma24112003@gmail.com" class="text-accent hover:underline text-lg font-mono">aryansharma24112003@gmail.com</a>
      </div>
    
    </div>
  </div>
</Layout>
