---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BentoGrid from '../components/BentoGrid.astro';
import ToolCard from '../components/ToolCard.astro';
import AdSlot from '../components/AdSlot.astro';

const tools = [
  {
    title: 'Digital Omnichord & Strum Plate',
    description: 'A premium, zero-latency web-based Omnichord. Build chords and strum dynamic harp-like arpeggios directly in your browser.',
    href: '/tools/omnichord',
    size: 'lg' as const,
  },
  {
    title: 'ATS Resume Matcher',
    description: 'Bypass applicant tracking systems. Analyze your resume against job descriptions to extract missing skills instantly.',
    href: '/tools/ats-matcher',
    size: 'md' as const,
  },
  {
    title: 'Bulk URL Extractor',
    description: 'Extract, clean, and batch-open URLs from messy text blocks securely in your browser.',
    href: '/tools/url-extractor',
    size: 'sm' as const,
  },
  {
    title: 'Ad-Blocker Generator',
    description: 'Generate a customized Manifest V3 zero-trust ad blocker extension on the fly.',
    href: '/tools/ad-blocker',
    size: 'sm' as const,
  },
  {
    title: 'Harmonium & Web Synth Studio',
    description: 'Play a realistic wooden harmonium and synthesize music directly in your browser with zero latency. Connect a MIDI keyboard and start playing instantly.',
    href: '/tools/midi-studio',
    size: 'lg' as const,
  },
  {
    title: 'Word Cloud Analyzer',
    description: 'Analyze keyword density and generate stunning high-res word clouds directly in your browser.',
    href: '/tools/word-cloud',
    size: 'tall' as const,
  },
  {
    title: 'JSON to Table Visualizer',
    description: 'Instantly transform dense, nested API payloads into highly readable, tabular formats with CSV export.',
    href: '/tools/json-visualizer',
    size: 'tall' as const,
  },
  {
    title: 'Free Video Compressor',
    description: 'Compress high-bitrate video assets locally to bypass transmission restrictions. No watermarks, unlimited size.',
    href: '/tools/video-compressor',
    size: 'md' as const,
  },
  {
    title: 'Audio Converter',
    description: 'Convert WAV, OGG, or Video tracks directly to MP3 without server uploads.',
    href: '/tools/audio-converter',
    size: 'md' as const,
  },
  {
    title: 'Device Mockup Studio',
    description: 'Wrap your app screenshots in beautiful 4K device frames instantly.',
    href: '/tools/mockup-studio',
    size: 'tall' as const,
  },
  {
    title: 'HD Background Remover',
    description: 'Use on-device AI to instantly remove backgrounds securely in your browser. Zero uploads.',
    href: '/tools/bg-remover',
    size: 'lg' as const,
  },
  {
    title: 'Image Vectorizer',
    description: 'Convert raster images (PNG/JPG) to scalable vector graphics (SVG) locally.',
    href: '/tools/image-vectorizer',
    size: 'tall' as const,
  },
  {
    title: 'CSV Data Sanitizer',
    description: 'Clean, format, and deduplicate messy B2B lead lists or CRM exports directly in your browser. Zero data leaves your device.',
    href: '/tools/csv-cleaner',
    size: 'lg' as const,
  },
  {
    title: 'Clean Reader Extractor',
    description: 'Paste any article URL to instantly extract the core text as clean Markdown, bypassing popups and ads.',
    href: '/tools/clean-reader',
    size: 'tall' as const,
  },
  {
    title: 'Image-to-Text OCR',
    description: 'Securely extract text from photos, scans, and screenshots using WASM-powered OCR.',
    href: '/tools/ocr-converter',
    size: 'tall' as const,
  },
  {
    title: 'Zero-Trust QR Studio',
    description: 'Generate permanent QR codes or scan them securely without leaving your browser. 100% private, zero tracking.',
    href: '/tools/qr-studio',
    size: 'tall' as const,
  },
  {
    title: 'Word & Character Counter',
    description: 'Count words, characters, sentences, and paragraphs instantly with real-time keyword density analysis.',
    href: '/tools/word-counter',
    size: 'lg' as const,
  },
  {
    title: 'Secure Password Generator',
    description: 'Generate strong, secure, and random passwords instantly right in your browser.',
    href: '/tools/password-generator',
    size: 'tall' as const,
  },
  {
    title: 'Color Picker & Palette Generator',
    description: 'Pick colors, generate beautiful palettes, and convert between HEX, RGB, and HSL instantly.',
    href: '/tools/color-picker',
    size: 'sm' as const,
  },
  {
    title: 'Unit Converter',
    description: 'Convert between length, weight, temperature, volume, and more instantly.',
    href: '/tools/unit-converter',
    size: 'sm' as const,
  },
  {
    title: 'Pomodoro Focus Timer',
    description: 'Boost productivity with customizable focus sessions, short breaks, and long breaks.',
    href: '/tools/pomodoro-timer',
    size: 'md' as const,
  },
  {
    title: 'Universal File Converter',
    description: 'Convert images, documents, and data files instantly without any server uploads.',
    href: '/tools/universal-converter',
    size: 'lg' as const,
  },
  {
    title: 'Universal File Compressor',
    description: 'Shrink images, minify text, and ZIP files directly in your browser.',
    href: '/tools/universal-compressor',
    size: 'tall' as const,
  },
  {
    title: 'Premium Vector (SVG) Optimizer',
    description: 'Minify paths, strip metadata, and compress SVG files by up to 80% instantly in your browser.',
    href: '/tools/svg-optimizer',
    size: 'tall' as const,
  },
  {
    title: 'Local HD Web Screen Recorder',
    description: 'Record unlimited high-definition video directly in your browser securely with zero server uploads.',
    href: '/tools/screen-recorder',
    size: 'tall' as const,
  },
  {
    title: 'AI-Powered Resume Bullet Optimizer',
    description: 'Transform weak resume bullets into high-impact, enterprise-grade achievement statements instantly.',
    href: '/tools/resume-optimizer',
    size: 'lg' as const,
  },
  {
    title: 'Corporate PDF Metadata Stripper',
    description: 'Wipe author, creator, location logs, and editing history from corporate PDF files securely.',
    href: '/tools/pdf-metadata-stripper',
    size: 'tall' as const,
  }
];
---

<Layout title="ToolGrid — Free Online Tools for Creators & Developers | No Signup" description="20+ free, blazing-fast browser tools: QR code generator, image background remover, video compressor, OCR, web harmonium, omnichord, JSON viewer, and more. 100% private — nothing leaves your browser." keywords="free online tools, web tools, browser tools, free qr code generator, background remover, video compressor, online harmonium, digital omnichord, ocr converter, image editor online, free developer tools, no signup tools, privacy tools">
  <Hero
    title="Powerful Tools, Premium Experience"
    subtitle="Creative Suite"
    description="Discover a curated collection of professional-grade tools designed for modern creators, developers, and designers."
    ctaLink="#tools"
  />

  <!-- Tools Grid -->
  <section id="tools" class="py-20 px-4">
    <div class="container mx-auto max-w-7xl">
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-balance">
          Explore Our Tools
        </h2>
        <p class="text-lg text-muted-foreground">
          Each tool is crafted with precision and attention to detail.
        </p>
      </div>

      <BentoGrid>
        {tools.map((tool) => (
          <ToolCard
            title={tool.title}
            description={tool.description}
            href={tool.href}
            size={tool.size}
          />
        ))}
      </BentoGrid>

      <div class="mt-16 w-full max-w-4xl mx-auto">
        <AdSlot />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="about" class="py-20 px-4 bg-gradient-to-b from-muted/5 to-transparent">
    <div class="container mx-auto max-w-7xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
        Why Choose ToolGrid?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border border-border rounded-lg p-8 bg-black/40 hover:border-accent transition-smooth">
          <div class="w-12 h-12 bg-muted/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Lightning Fast</h3>
          <p class="text-sm text-muted-foreground">
            Optimized performance for seamless workflows.
          </p>
        </div>

        <div class="border border-border rounded-lg p-8 bg-black/40 hover:border-accent transition-smooth">
          <div class="w-12 h-12 bg-muted/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Always Secure</h3>
          <p class="text-sm text-muted-foreground">
            Enterprise-grade security for your peace of mind.
          </p>
        </div>

        <div class="border border-border rounded-lg p-8 bg-black/40 hover:border-accent transition-smooth">
          <div class="w-12 h-12 bg-muted/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Fully Customizable</h3>
          <p class="text-sm text-muted-foreground">
            Tailor every tool to your specific needs.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
