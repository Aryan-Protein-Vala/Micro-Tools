---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog & Updates | ToolGrid" description="Read the latest news, updates, and tutorials from the ToolGrid team.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl py-20">
    <div class="prose prose-invert prose-lg max-w-none">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">Blog & Updates</h1>
      
      <p class="text-muted-foreground text-xl">Coming soon...</p>
      <p class="text-muted-foreground mt-4">We are currently writing our first batch of articles regarding browser-based WASM engineering and modern web development.</p>
    
    </div>
  </div>
</Layout>
