---
// MidiWorkspace.astro
---
<div class="h-full flex flex-col lg:flex-row gap-6 pb-20">
  
  <!-- Left Panel: Main Stage (Keyboard) -->
  <div class="flex-1 bg-[#0a0a0a] border border-white/10 rounded-xl flex flex-col overflow-hidden shadow-2xl">
    
    <!-- Top Control Bar -->
    <div class="h-14 border-b border-white/10 flex items-center justify-between px-6 bg-[#0f0f0f]">
      <div class="flex items-center gap-4">
        <label for="synth-type" class="text-xs font-semibold tracking-wider text-white/70 uppercase">Oscillator</label>
        <select id="synth-type" class="bg-transparent border border-white/20 rounded px-3 py-1 text-sm text-white focus:outline-none focus:border-white/50 transition-colors">
          <option value="sine" class="bg-[#111]">Electric Piano</option>
          <option value="harmonium" class="bg-[#111]">Harmonium</option>
          <option value="guitar" class="bg-[#111]">Guitar (Pluck)</option>
          <option value="triangle" class="bg-[#111]">Flute</option>
          <option value="square" class="bg-[#111]">Classic Synth</option>
          <option value="sawtooth" class="bg-[#111]">Brass/Lead</option>
        </select>
      </div>

      <div class="flex items-center gap-3">
        <div id="init-btn" class="cursor-pointer text-xs font-semibold px-4 py-1.5 border border-white/20 rounded hover:bg-white/5 transition-colors text-white">
          Click to Start Audio
        </div>
      </div>
    </div>

    <!-- Keyboard Stage -->
    <div class="flex-1 flex items-center justify-center p-8 overflow-x-auto">
      <div id="keyboard-container" class="relative flex h-48 sm:h-64 rounded-b border-t-8 border-[#1a1a1a] shadow-inner select-none">
        <!-- White Keys (Generated via JS) -->
      </div>
    </div>
    
    <!-- Instruction Footer -->
    <div class="h-10 border-t border-white/5 flex items-center justify-center bg-[#0a0a0a]">
      <span class="text-xs text-white/40">Use QWERTY keyboard matching the layout, or connect a USB MIDI Controller.</span>
    </div>

  </div>

  <!-- Right Panel: Context & Effects -->
  <div class="w-full lg:w-80 flex flex-col gap-6">
    
    <!-- Connection Status -->
    <div class="bg-[#0a0a0a] border border-white/10 rounded-xl p-6">
      <h3 class="text-sm font-semibold tracking-wider text-white/70 uppercase mb-4">Hardware Status</h3>
      <div class="flex items-center justify-between">
        <span class="text-sm text-white/90">MIDI Controller</span>
        <div class="flex items-center gap-2">
          <span id="midi-status-indicator" class="w-2.5 h-2.5 rounded-full bg-red-500/80 shadow-[0_0_8px_rgba(239,68,68,0.5)]"></span>
          <span id="midi-status-text" class="text-xs font-mono text-white/50">Disconnected</span>
        </div>
      </div>
    </div>

    <!-- Modulation Modules -->
    <div class="flex-1 flex flex-col gap-4">
      
      <!-- Transpose -->
      <div class="bg-white rounded shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-slate-600 text-white text-center py-2 text-sm font-medium tracking-wide">
          Transpose - <span id="val-transpose">0</span>
        </div>
        <div class="flex items-center justify-between p-3 bg-gray-50">
          <button id="btn-trans-down" class="w-12 py-1.5 bg-gray-400 hover:bg-gray-500 text-white font-bold rounded shadow-sm transition-colors">-</button>
          <span id="lbl-transpose" class="font-mono text-gray-800 font-semibold">0</span>
          <button id="btn-trans-up" class="w-12 py-1.5 bg-gray-400 hover:bg-gray-500 text-white font-bold rounded shadow-sm transition-colors">+</button>
        </div>
      </div>

      <!-- Current Octave -->
      <div class="bg-white rounded shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-slate-600 text-white text-center py-2 text-sm font-medium tracking-wide">
          Current Octave
        </div>
        <div class="flex items-center justify-between p-3 bg-gray-50">
          <button id="btn-oct-down" class="w-12 py-1.5 bg-gray-400 hover:bg-gray-500 text-white font-bold rounded shadow-sm transition-colors">-</button>
          <span id="lbl-octave" class="font-mono text-gray-800 font-semibold">3</span>
          <button id="btn-oct-up" class="w-12 py-1.5 bg-gray-400 hover:bg-gray-500 text-white font-bold rounded shadow-sm transition-colors">+</button>
        </div>
      </div>

      <!-- Additional Reeds -->
      <div class="bg-white rounded shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-slate-600 text-white text-center py-2 text-sm font-medium tracking-wide">
          Additional Reeds
        </div>
        <div class="flex items-center justify-between p-3 bg-gray-50">
          <button id="btn-reed-down" class="w-12 py-1.5 bg-gray-400 hover:bg-gray-500 text-white font-bold rounded shadow-sm transition-colors">-</button>
          <span id="lbl-reed" class="font-mono text-gray-800 font-semibold">0</span>
          <button id="btn-reed-up" class="w-12 py-1.5 bg-gray-400 hover:bg-gray-500 text-white font-bold rounded shadow-sm transition-colors">+</button>
        </div>
      </div>

      <!-- Master Volume -->
      <div class="bg-[#0a0a0a] border border-white/10 rounded-xl p-6 mt-2">
        <div class="flex justify-between mb-2">
          <label class="text-xs text-white/60 uppercase font-semibold">Master Vol</label>
          <span id="val-vol" class="text-xs font-mono text-white/40">-10 dB</span>
        </div>
        <input type="range" id="master-vol" min="-40" max="0" value="-10" class="w-full accent-white/80 h-1 bg-white/10 rounded-full appearance-none cursor-pointer" />
      </div>
    </div>

    <!-- AdSlot -->
    <div class="bg-[#0a0a0a] border border-white/5 rounded-xl h-48 flex flex-col items-center justify-center text-center p-4 shadow-sm relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <span class="text-xs tracking-widest text-white/20 uppercase mb-2">Advertisement</span>
      <p class="text-sm text-white/40">Support free tools by whitelisting us.</p>
    </div>

  </div>
</div>

<style>
  /* Base reset for sliders to match aesthetic */
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 12px;
    height: 12px;
    background: #fff;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(255,255,255,0.3);
  }
</style>
