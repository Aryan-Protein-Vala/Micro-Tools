---
export interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  size?: 'sm' | 'md' | 'tall' | 'lg';
  featured?: boolean;
}

const {
  title,
  description,
  icon,
  href = '#',
  size = 'md',
  featured = false,
} = Astro.props;

const sizeClasses = {
  sm: 'col-span-1 row-span-1',
  md: 'col-span-1 sm:col-span-2 row-span-1',
  tall: 'col-span-1 row-span-2',
  lg: 'col-span-1 sm:col-span-2 md:col-span-2 row-span-2',
};
---

<a
  href={href}
  class:list={[
    'group relative overflow-hidden rounded-xl border border-border bg-black/40 p-6 transition-smooth hover:border-accent hover:bg-black/60',
    sizeClasses[size],
    {
      'md:col-span-2 md:row-span-2': featured,
    },
  ]}
>
  <!-- Gradient overlay on hover -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-5 bg-gradient-to-br from-accent to-transparent transition-smooth"></div>

  <!-- Content -->
  <div class="relative h-full flex flex-col justify-between">
    {icon && (
      <div class="mb-4 text-4xl">
        <span set:html={icon} />
      </div>
    )}

    <div>
      <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-accent transition-colors text-balance">
        {title}
      </h3>
      <p class="text-sm text-muted-foreground group-hover:text-muted transition-colors">
        {description}
      </p>
    </div>

    <!-- Arrow indicator -->
    <div class="mt-6 flex items-center gap-2 text-muted-foreground group-hover:text-accent transition-colors opacity-0 group-hover:opacity-100 transition-opacity">
      <span class="text-xs font-medium">Explore</span>
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
  </div>
</a>

<style>
  a {
    display: flex;
    flex-direction: column;
  }
</style>
