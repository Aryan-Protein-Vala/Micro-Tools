---
// OmnichordWorkspace.astro
import AdSlot from './AdSlot.astro';

const roots = ['F', 'C', 'G', 'D', 'A', 'E', 'B', 'F#', 'C#', 'G#', 'D#', 'A#'];
const qualities = ['Maj', 'Min', '7th', 'Maj7', 'Min7', 'Dim', 'Aug'];
---

<div class="h-full flex flex-col lg:flex-row gap-6 pb-20 select-none">
  
  <!-- Left Panel: Main Stage (65%) -->
  <div class="w-full lg:w-[65%] flex flex-col md:flex-row gap-6">
    
    <!-- Chord Matrix -->
    <div class="flex-1 bg-[#18181b] border border-[#27272a] rounded-xl p-4 sm:p-6 shadow-2xl flex flex-col relative overflow-hidden">
      <!-- Ambient Background Glow -->
      <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-white/[0.02] to-transparent pointer-events-none"></div>

      <div class="flex items-center justify-between mb-6 relative z-10">
        <h3 class="text-sm font-semibold tracking-wider text-white/70 uppercase">Chord Matrix</h3>
        <div class="flex items-center gap-2">
          <button id="btn-expand-matrix" class="cursor-pointer text-[10px] font-bold tracking-widest uppercase px-3 py-1.5 border border-[#27272a] rounded hover:bg-white/5 transition-colors text-white/70 focus:outline-none">
            Fit to Screen
          </button>
          <div id="init-btn" class="cursor-pointer text-[10px] font-bold tracking-widest uppercase px-3 py-1.5 border border-[#27272a] rounded hover:bg-white/5 transition-colors text-white/50">
            Awaiting Init
          </div>
        </div>
      </div>

      <!-- Matrix Grid -->
      <div class="overflow-x-auto overflow-y-hidden flex-1 relative z-10 w-full scrollbar-thin scrollbar-thumb-white/10 scrollbar-track-transparent pr-2 pb-2">
        <div class="grid grid-cols-12 gap-1 sm:gap-2 min-w-[700px] h-full items-center" id="chord-matrix">
          {qualities.map(q => (
            roots.map(r => (
              <button 
                class="chord-btn relative h-10 sm:h-12 rounded border border-[#27272a] bg-[#09090b] text-white/40 font-bold flex flex-col items-center justify-center transition-all hover:border-white/20 overflow-hidden group focus:outline-none"
                data-chord={`${r}${q}`}
              >
                <div class="absolute inset-0 bg-white/0 group-hover:bg-white/5 transition-colors pointer-events-none"></div>
                <span class="relative z-10 text-[11px] pointer-events-none">{r}</span>
                <span class="relative z-10 text-[9px] font-normal opacity-70 pointer-events-none">{q}</span>
              </button>
            ))
          ))}
        </div>
      </div>
    </div>

    <!-- Strum Plate -->
    <div class="w-full md:w-28 lg:w-36 bg-[#09090b] border border-[#27272a] rounded-xl relative overflow-hidden shadow-inner flex flex-col items-center justify-center shrink-0 cursor-crosshair touch-none group" id="strum-plate">
      <div class="absolute inset-0 bg-gradient-to-b from-white/0 via-white/[0.01] to-white/0 pointer-events-none"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-between py-8 opacity-20 pointer-events-none">
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
        <div class="w-1 h-1 rounded-full bg-white"></div>
      </div>
      <canvas id="strum-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
    </div>

  </div>

  <!-- Right Panel: Context (35%) -->
  <div class="w-full lg:w-[35%] flex flex-col gap-6">
    
    <!-- Rhythm Section -->
    <div class="bg-[#18181b] border border-[#27272a] rounded-xl p-6">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-sm font-semibold tracking-wider text-white/70 uppercase">Rhythm Box</h3>
        <button id="btn-rhythm-toggle" class="w-10 h-5 rounded-full bg-[#09090b] border border-[#27272a] relative transition-colors focus:outline-none">
          <div class="w-3 h-3 rounded-full bg-white/30 absolute top-[3px] left-[3px] transition-all" id="rhythm-thumb"></div>
        </button>
      </div>

      <div class="space-y-6">
        <div>
          <div class="flex justify-between mb-2">
            <label class="text-xs text-white/50">Tempo</label>
            <span id="val-bpm" class="text-xs font-mono text-white/40">120 BPM</span>
          </div>
          <input type="range" id="master-bpm" min="60" max="200" step="1" value="120" class="w-full accent-white/80 h-1 bg-white/10 rounded-full appearance-none cursor-pointer" />
        </div>
        <div>
          <div class="flex justify-between mb-2">
            <label class="text-xs text-white/50">Level</label>
            <span id="val-rhythm-vol" class="text-xs font-mono text-white/40">-15 dB</span>
          </div>
          <input type="range" id="rhythm-vol" min="-40" max="0" step="1" value="-15" class="w-full accent-white/80 h-1 bg-white/10 rounded-full appearance-none cursor-pointer" />
        </div>
      </div>
    </div>

    <!-- Engine Settings -->
    <div class="bg-[#18181b] border border-[#27272a] rounded-xl p-6 flex-1">
      <h3 class="text-sm font-semibold tracking-wider text-white/70 uppercase mb-6">Engine</h3>
      
      <div class="space-y-6">
        <div>
          <div class="flex justify-between mb-2">
            <label class="text-xs text-white/50">Master Reverb</label>
            <span id="val-reverb" class="text-xs font-mono text-white/40">30%</span>
          </div>
          <input type="range" id="master-reverb" min="0" max="100" step="1" value="30" class="w-full accent-white/80 h-1 bg-white/10 rounded-full appearance-none cursor-pointer" />
        </div>

        <div class="h-px w-full bg-white/5 my-4"></div>

        <div>
          <div class="flex justify-between mb-2">
            <label class="text-xs text-white/50">Master Vol</label>
            <span id="val-vol" class="text-xs font-mono text-white/40">-10 dB</span>
          </div>
          <input type="range" id="master-vol" min="-40" max="0" step="1" value="-10" class="w-full accent-white/80 h-1 bg-white/10 rounded-full appearance-none cursor-pointer" />
        </div>
      </div>
    </div>

    <!-- AdSlot -->
    <AdSlot variant="global" />

  </div>
</div>

<style>
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 12px;
    height: 12px;
    background: #fff;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(255,255,255,0.2);
  }
</style>

<script>
  const expandBtn = document.getElementById('btn-expand-matrix');
  const matrixContainer = document.getElementById('chord-matrix');
  
  if (expandBtn && matrixContainer) {
    let isExpanded = true;
    
    expandBtn.addEventListener('click', () => {
      isExpanded = !isExpanded;
      if (isExpanded) {
        matrixContainer.classList.add('min-w-[700px]');
        expandBtn.textContent = 'Fit to Screen';
      } else {
        matrixContainer.classList.remove('min-w-[700px]');
        expandBtn.textContent = 'Expand Matrix';
      }
    });
  }
</script>
