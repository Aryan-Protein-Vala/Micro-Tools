---
// AdSlot.astro
interface Props {
  className?: string;
  variant?: 'global' | 'synth';
}

const { className = '', variant = 'global' } = Astro.props;

const globalClasses = "bg-card border border-border rounded-xl h-32 md:h-48 flex flex-col items-center justify-center text-center p-4 shadow-sm relative overflow-hidden group hover:border-border/80 transition-colors";
const synthClasses = "bg-[#0a0a0a] border border-white/5 rounded-xl h-48 flex flex-col items-center justify-center text-center p-4 shadow-sm relative overflow-hidden group";

const containerClasses = variant === 'synth' ? synthClasses : globalClasses;
const titleClasses = variant === 'synth' ? "text-white/20" : "text-muted-foreground/50";
const textClasses = variant === 'synth' ? "text-white/40" : "text-muted-foreground";
const gradientClasses = variant === 'synth' ? "from-white/5" : "from-foreground/5";
---

<div class={`${containerClasses} ${className}`}>
  <div class={`absolute inset-0 bg-gradient-to-br ${gradientClasses} to-transparent opacity-0 group-hover:opacity-100 transition-opacity`}></div>
  <span class={`text-xs tracking-widest uppercase mb-2 ${titleClasses}`}>Advertisement</span>
  <p class={`text-sm ${textClasses}`}>Support free tools by whitelisting us.</p>
</div>
