---
import RelatedTools from './RelatedTools.astro';
import AdSlot from './AdSlot.astro';

export interface Props {
  title: string;
  toolName: string;
  children?: any;
  hasContextPanel?: boolean;
}

const {
  title,
  toolName,
  hasContextPanel = true,
} = Astro.props;
---

<div class="min-h-screen bg-background flex flex-col">
  <!-- Workspace Header -->
  <header class="border-b border-border bg-black/40 backdrop-blur-sm sticky top-16 z-40">
    <div class="px-6 py-4 flex items-center justify-between">
      <div>
        <p class="text-xs text-muted-foreground mb-1">Tool</p>
        <h1 class="text-2xl font-bold text-foreground">{title}</h1>
      </div>
      <button id="share-btn" class="px-4 py-2 bg-accent text-background rounded-md text-sm font-medium hover:bg-muted-foreground transition-smooth cursor-pointer">
        Share
      </button>
    </div>
  </header>

  <!-- Main Content -->
  <div class="flex flex-1 overflow-hidden gap-4 p-4">
    <!-- Main Stage (65%) -->
    <div class="flex-1 min-w-0">
      <div class="h-full bg-black/40 rounded-lg border border-border p-6 overflow-auto">
        <slot />
      </div>
    </div>

    <!-- Context Panel (35%) - Conditional -->
    {hasContextPanel && (
      <aside class="hidden lg:flex lg:w-[35%] flex-col gap-4">
        <!-- Utility Zone -->
        {Astro.slots.has('controls') && (
          <div class="bg-black/40 rounded-lg border border-border p-4">
            <h3 class="text-sm font-bold text-foreground mb-4">Controls</h3>
            <div class="space-y-3">
              <slot name="controls" />
            </div>
          </div>
        )}

        <!-- Ad Slot -->
        <div class="mb-6">
          <AdSlot />
        </div>

        <!-- FAQ -->
        <div class="bg-black/40 rounded-lg border border-border p-4 flex-1 overflow-auto">
          <h3 class="text-sm font-bold text-foreground mb-4">FAQ</h3>
          <div class="space-y-3">
            <slot name="faq">
              <details class="group">
                <summary class="cursor-pointer text-sm font-medium text-foreground hover:text-accent transition-colors">
                  How do I get started?
                </summary>
                <p class="mt-2 text-xs text-muted-foreground pl-4 border-l border-border">
                  Begin by exploring the controls on the left. Each tool has its own interface.
                </p>
              </details>
              <details class="group">
                <summary class="cursor-pointer text-sm font-medium text-foreground hover:text-accent transition-colors">
                  Can I save my work?
                </summary>
                <p class="mt-2 text-xs text-muted-foreground pl-4 border-l border-border">
                  Yes, click the Save button to store your project in the cloud.
                </p>
              </details>
              <details class="group">
                <summary class="cursor-pointer text-sm font-medium text-foreground hover:text-accent transition-colors">
                  How do I export?
                </summary>
                <p class="mt-2 text-xs text-muted-foreground pl-4 border-l border-border">
                  Use the Export button to download your work in multiple formats.
                </p>
              </details>
            </slot>
          </div>
        </div>
      </aside>
    )}
  </div>

  <!-- Related Tools (Internal Linking for SEO) -->
  <div class="px-4 pb-6">
    <RelatedTools currentTool={toolName} />
  </div>
</div>

<script is:inline>
  const shareBtn = document.getElementById('share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const originalText = shareBtn.innerText;
        shareBtn.innerText = 'Copied!';
        setTimeout(() => {
          shareBtn.innerText = originalText;
        }, 2000);
      } catch (err) {
        console.error('Failed to copy!', err);
      }
    });
  }
</script>
