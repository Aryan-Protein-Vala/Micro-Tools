<section class="relative pt-24 pb-16 px-6 overflow-hidden flex flex-col items-center text-center w-full">
  <!-- Mesh Gradient Background -->
  <div class="absolute inset-0 bg-mesh-gradient opacity-60 pointer-events-none -z-10"></div>
  
  <div class="max-w-[768px] w-full z-10 flex flex-col items-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-canvas-soft border border-hairline mb-8 shadow-sm">
      <span class="flex h-2 w-2 rounded-full bg-link"></span>
      <span class="text-xs font-medium text-body">Creator Tools v1.0</span>
    </div>
    
    <h1 class="text-[48px] leading-[48px] tracking-[-2.4px] font-semibold text-ink mb-6">
      Generate timestamps & hooks from raw scripts.
    </h1>
    
    <p class="text-[18px] leading-[28px] text-body max-w-[576px] mb-10">
      Paste your raw, unformatted video script or transcript. We'll automatically build YouTube-ready chapters and extract high-retention viral hooks. 100% client-side.
    </p>

    <div class="flex gap-4">
      <a href="#splitter" class="h-10 px-6 bg-ink text-canvas font-medium text-sm rounded-minimal hover:bg-primary transition-colors flex items-center shadow-level-2">
        Start Splitting
      </a>
      <a href="#" class="h-10 px-6 bg-canvas text-ink font-medium text-sm rounded-minimal border border-hairline hover:bg-canvas-soft transition-colors flex items-center shadow-sm">
        View Examples
      </a>
    </div>
  </div>
</section>
