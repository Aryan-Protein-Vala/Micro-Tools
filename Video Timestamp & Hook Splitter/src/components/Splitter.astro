---
---
<section id="splitter" class="max-w-[1152px] mx-auto px-6 py-16 w-full flex flex-col gap-8">
  
  <div class="bg-primary rounded-lg p-6 shadow-level-4">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
        <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
      </div>
      <span class="text-mute font-mono text-xs">video_script.txt</span>
      <div class="w-16"></div> <!-- spacer -->
    </div>
    
    <textarea 
      id="script-input" 
      class="w-full h-64 bg-transparent text-on-primary font-mono text-[13px] resize-y outline-none border-none placeholder-mute leading-5"
      placeholder="Paste your raw video script, transcript, or ideas here..."
    ></textarea>
    
    <div class="flex justify-end mt-4">
      <button id="btn-process" class="bg-canvas text-ink text-sm font-medium px-4 py-2 rounded-md hover:bg-canvas-soft transition-colors shadow-sm">
        Generate Timestamps & Hooks
      </button>
    </div>
  </div>

  <!-- Output Panes -->
  <div id="output-container" class="hidden grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
    
    <!-- Timestamps Pane -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-ink">YouTube Timestamps</h3>
        <button id="btn-copy-timestamps" class="text-xs font-medium text-mute hover:text-ink transition-colors flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          Copy
        </button>
      </div>
      <div class="bg-canvas-soft border border-hairline rounded-md p-4 shadow-sm relative group">
        <pre id="timestamps-output" class="font-mono text-sm text-body whitespace-pre-wrap leading-6"></pre>
      </div>
    </div>

    <!-- Hooks Pane -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-ink">Viral Hooks Extracted</h3>
        <button id="btn-copy-hooks" class="text-xs font-medium text-mute hover:text-ink transition-colors flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          Copy
        </button>
      </div>
      <div class="bg-canvas-soft border border-hairline rounded-md p-4 shadow-sm relative group max-h-96 overflow-y-auto">
        <div id="hooks-output" class="flex flex-col gap-3"></div>
      </div>
    </div>
    
  </div>

</section>

<script>
  import { initSplitter } from '../scripts/splitter-engine.js';
  document.addEventListener('DOMContentLoaded', () => {
    initSplitter();
  });
</script>
