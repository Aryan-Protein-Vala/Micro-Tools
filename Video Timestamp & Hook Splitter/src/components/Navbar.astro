<header class="sticky top-0 z-50 bg-canvas/80 backdrop-blur-md border-b border-hairline h-16 w-full px-6 flex items-center justify-between">
  
  <!-- Logo Section -->
  <div class="flex items-center gap-6">
    <a href="/" class="flex items-center gap-2 text-ink font-semibold tracking-tight hover:opacity-80 transition-opacity">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="23 7 16 12 23 17 23 7"></polygon>
        <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
      </svg>
      Creator Splitter
    </a>
    
    <!-- Navigation Links -->
    <nav class="hidden md:flex items-center gap-4 text-sm font-medium text-mute">
      <a href="#" class="hover:text-ink transition-colors">Documentation</a>
      <a href="#" class="hover:text-ink transition-colors">Pricing</a>
      <a href="#" class="hover:text-ink transition-colors">Enterprise</a>
    </nav>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3">
    <a href="#" class="text-sm font-medium text-mute hover:text-ink transition-colors hidden sm:block mr-2">Contact</a>
    <a href="#" class="h-8 flex items-center justify-center px-3 bg-canvas border border-hairline rounded-minimal text-sm font-medium text-ink hover:bg-canvas-soft transition-colors shadow-sm">
      Log In
    </a>
    <a href="#" class="h-8 flex items-center justify-center px-3 bg-ink rounded-minimal text-sm font-medium text-canvas hover:bg-primary transition-colors shadow-sm">
      Sign Up
    </a>
  </div>
  
</header>
